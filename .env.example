# Environment variables for Reclaim.
# These are passed to the container via docker-compose or exported for local dev.
# Do NOT put credentials here — they are set via the first-run setup page.

# Required: absolute paths to media libraries (rw for in-place replace)
MOVIES_PATH=/path/to/movies
TV_PATH=/path/to/tv

# Required: SQLite database location (should be on a named volume in Docker)
DB_PATH=/data/reclaim.db

# Encode window — worker only pulls jobs inside this range (24h local time)
ENCODE_WINDOW_START=00:00
ENCODE_WINDOW_END=06:00

# How often a diff-based safety-net rescan runs
SCAN_INTERVAL=24h

# Daily scan anchor time (HH:MM, local) — used with SCAN_INTERVAL
SCAN_ANCHOR=00:00

# Container timezone — set in Docker so the encode window matches your local clock
# TZ=America/New_York

# Docker only — uid/gid that owns your media library (see docker-compose.yml)
# PUID=1000
# PGID=1000

# Max parallel ffprobe calls during a scan
PROBE_CONCURRENCY=4

# TMDB API key — optional, for movie/TV poster and metadata fetching.
# Copy .env.example to .env and set your key here — .env is gitignored.
# TMDB_API_KEY=your_api_key_here

# Auth escape hatches (both default false — only set in specific recovery scenarios)
# DISABLE_AUTH=false    # bypass login entirely (trusted LAN only)
# RESET_AUTH=false      # clear stored credentials on boot → re-runs first-run setup
